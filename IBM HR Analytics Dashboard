// ─── TAB SWITCHING ───────────────────────────────────
function switchTab(name) {
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.nav-tab').forEach(t=>t.classList.remove('active'));
  document.getElementById('page-'+name).classList.add('active');
  document.getElementById('tab-'+name).classList.add('active');
}

// ─── FILTER LOGIC ────────────────────────────────────
let filters = {attr:'All',gender:'All',ot:'All'};

function toggleChip(el, type, val) {
  const siblings = el.parentElement.querySelectorAll('.filter-chip');
  siblings.forEach(c=>c.classList.remove('active'));
  el.classList.add('active');
  filters[type] = val;
}

function resetFilters() {
  document.getElementById('f-dept').value='All';
  document.querySelectorAll('.filter-chip').forEach(c=>{
    if(c.textContent==='All') c.classList.add('active');
    else c.classList.remove('active');
  });
  filters={attr:'All',gender:'All',ot:'All'};
}

